{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build SFML Project",
            "type": "shell",
            "command": "/opt/homebrew/opt/llvm/bin/clang++",
            "args": [
                "-std=c++23",
                "-arch", "arm64",
                "src/main.cpp",
                "-I/opt/homebrew/include",
                "-L/usr/local/lib",
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system",
                "-lsfml-audio",
                "-lsfml-network",
                "-I../../libraries/ImGui-SFML/imgui",
                "-I../../libraries/ImGui-SFML",
                "-framework", "Cocoa",
                "-framework", "OpenGL",
                "-framework", "IOKit",
                "-framework", "CoreVideo",
                "-o", "build/BouncyShapes-GUI",
                "-Wl,-rpath,/usr/local/lib"
            ],
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"],
            "options": { "cwd": "${workspaceFolder}" },
            "osx": true
        }
    ]
}