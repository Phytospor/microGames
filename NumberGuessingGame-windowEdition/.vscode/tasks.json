{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build SFML Project",
            "type": "shell",
            "command": "/opt/homebrew/opt/llvm/bin/clang++",
            "args": [
                "-std=c++23",
                "-arch", "arm64",
                "src/main.cpp",
                "src/Game.cpp",
                "-o", "build/NumberGuessingGame",
                "-I/opt/homebrew/Cellar/sfml/3.0.2/include",
                "-I${workspaceFolder}/include",
                "-L/opt/homebrew/Cellar/sfml/3.0.2/lib",
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system",
                "-framework", "Cocoa",
                "-framework", "OpenGL",
                "-framework", "IOKit",
                "-framework", "CoreVideo"
            ],
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"],
            "options": { "cwd": "${workspaceFolder}" },
            "osx": true
        }
    ]
}